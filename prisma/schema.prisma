// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  INTERN
  CONTRACT
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  NOTICE_PERIOD
  RESIGNED
  TERMINATED
}

enum DocumentType {
  PROFILE_PHOTO
  AADHAAR
  PAN
  PASSPORT
  RESUME
  OFFER_LETTER
  APPOINTMENT_LETTER
  EXPERIENCE_LETTER
  RELIEVING_LETTER
  SALARY_SLIP
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY
  WEEK_OFF
}

enum LeaveTypeCategory {
  CASUAL
  SICK
  EARNED
  LOSS_OF_PAY
  MATERNITY
  PATERNITY
  OTHER
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveDuration {
  FULL_DAY
  FIRST_HALF
  SECOND_HALF
}

model User {
  id          String   @id @default(cuid())
  supabaseId  String   @unique
  email       String   @unique
  isActive    Boolean  @default(true)

  companyId String
  roleId    String

  company Company @relation(fields: [companyId], references: [id])
  role    Role    @relation(fields: [roleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([roleId])
}

model Company {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  gstNumber String?
  pfNumber  String?
  esicNumber String?
  address   String?
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
  employees Employee[]
  bankAccounts BankAccount[]
  documents EmployeeDocument[]
  attendance Attendance[]
  leaveTypes LeaveType[]

  leaveRequests LeaveRequest[]

  leaveBalances LeaveBalance[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  code String @unique
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]
}

model Designation {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  code String @unique
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]
}

model Employee {
  id                 String            @id @default(cuid())

  employeeCode       String            @unique

  firstName          String
  lastName           String

  fatherName         String?

  dateOfBirth        DateTime

  gender             Gender

  mobile             String

  email              String            @unique


  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  country      String?
  postalCode   String?

  emergencyContactName String?
  emergencyContactPhone String?
  emergencyContactRelation String?

  profilePhotoUrl String?

  aadhaarNumber      String?           @unique

  panNumber          String?           @unique

  uanNumber          String?           @unique

  esicNumber         String?           @unique

  dateOfJoining      DateTime

  employmentType     EmploymentType

  status             EmployeeStatus    @default(ACTIVE)

  companyId          String
  departmentId       String
  designationId      String

  bankAccount BankAccount?

  documents EmployeeDocument[]

  attendance Attendance[]

  leaveRequests LeaveRequest[]

  leaveBalances LeaveBalance[]

  company            Company           @relation(fields: [companyId], references: [id])

  department         Department        @relation(fields: [departmentId], references: [id])

  designation        Designation       @relation(fields: [designationId], references: [id])

  deletedAt DateTime?

  createdAt          DateTime          @default(now())

  updatedAt          DateTime          @updatedAt

  @@index([employeeCode])
  @@index([departmentId])
  @@index([designationId])
  @@index([status])
}

model BankAccount {
  id              String   @id @default(cuid())

  employeeId      String   @unique

  companyId       String

  bankName        String

  branchName      String?

  accountHolder   String

  accountNumber   String

  ifscCode        String

  accountType     String?

  isPrimary       Boolean @default(true)

  createdAt       DateTime @default(now())

  updatedAt       DateTime @updatedAt

  deletedAt       DateTime?

  employee Employee @relation(fields: [employeeId], references: [id])

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])

  @@index([employeeId])
}

model EmployeeDocument {

  id String @id @default(cuid())

  employeeId String

  companyId String

  type DocumentType

  fileName String

  fileUrl String

  fileSize Int?

  mimeType String?

  remarks String?

  uploadedAt DateTime @default(now())

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  employee Employee @relation(fields: [employeeId], references: [id])

  company Company @relation(fields: [companyId], references: [id])

  @@index([employeeId])

  @@index([companyId])

  @@index([type])
}

model Attendance {
  id              String             @id @default(cuid())

  employeeId      String
  companyId       String

  attendanceDate  DateTime

  checkInTime     DateTime?

  checkOutTime    DateTime?

  workingMinutes  Int?

  overtimeMinutes Int? @default(0)

  status          AttendanceStatus

  remarks         String?

  createdAt       DateTime @default(now())

  updatedAt       DateTime @updatedAt

  deletedAt       DateTime?

  employee Employee @relation(fields: [employeeId], references: [id])

  company Company @relation(fields: [companyId], references: [id])

  @@unique([employeeId, attendanceDate])

  @@index([companyId])

  @@index([attendanceDate])

  @@index([status])

  @@index([employeeId])
}

model LeaveType {

  id String @id @default(cuid())

  companyId String

  name String

  code String

  category LeaveTypeCategory

  isPaid Boolean @default(true)

  annualAllocation Int

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  company Company @relation(fields: [companyId], references: [id])

  leaveRequests LeaveRequest[]

  leaveBalances LeaveBalance[]

  @@unique([companyId, code])

  @@index([companyId])
}

model LeaveRequest {

  id String @id @default(cuid())

  employeeId String

  companyId String

  leaveTypeId String

  startDate DateTime

  endDate DateTime

  totalDays Float

  duration LeaveDuration

  reason String?

  status LeaveRequestStatus @default(PENDING)

  approvedByUserId String?

  approvedAt DateTime?

  rejectionReason String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  employee Employee @relation(fields: [employeeId], references: [id])

  company Company @relation(fields: [companyId], references: [id])

  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([employeeId])

  @@index([companyId])

  @@index([status])

  @@index([startDate])

}

model LeaveBalance {

  id String @id @default(cuid())

  employeeId String

  companyId String

  leaveTypeId String

  year Int

  allocated Float

  used Float

  remaining Float

  carriedForward Float @default(0)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  company Company @relation(fields: [companyId], references: [id])

  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])

  @@index([companyId])

}